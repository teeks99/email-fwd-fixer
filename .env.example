# PassThrough IMAP (Where emails are initially received)
PASSTHROUGH_IMAP_SERVER=imap.example.com
PASSTHROUGH_IMAP_PORT=993
PASSTHROUGH_IMAP_USER=me-pass-through@example.com
PASSTHROUGH_IMAP_PASS=your_password

# GMail IMAP (Where we check if the email arrived - Read Only)
GMAIL_IMAP_SERVER=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_IMAP_USER=example-me@gmail.com
GMAIL_IMAP_PASS=your_app_password

# Notify IMAP (Where we copy the email if it didn't reach GMail)
NOTIFY_IMAP_SERVER=imap.example.com
NOTIFY_IMAP_PORT=993
NOTIFY_IMAP_USER=me-notify@example.com
NOTIFY_IMAP_PASS=your_password

# Script Settings
CHECK_INTERVAL_SECONDS=300
